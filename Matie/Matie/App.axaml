<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Matie.Converters"
             x:Class="Matie.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <conv:ImageBytesToBitmapConverter x:Key="ImageBytesToBitmapConverter" />
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
